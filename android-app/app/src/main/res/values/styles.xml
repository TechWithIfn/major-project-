<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ShikshaSahayak" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#050813</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/surface</item>
    </style>

    <style name="Theme.ShikshaSahayak.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A1030</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.ShikshaSahayak</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

</resources>
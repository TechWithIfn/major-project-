# Optional: Public site URL for SEO (canonical, sitemap). Default: https://shikshasahayak.com
# NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Optional: Use OpenAI for chat responses. If unset, the app uses the built-in heuristic fallback.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override local Python backend endpoint used by server API route.
# LOCAL_BACKEND_URL=http://localhost:5000/ask
